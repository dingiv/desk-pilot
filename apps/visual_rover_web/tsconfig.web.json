{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    // "noEmit": true,
    "lib": [
      "ES2023",
      "DOM",
      "DOM.Iterable"
    ],
    "types": [
      "vite/client",
      "node"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "useDefineForClassFields": true,
    "isolatedModules": true
  },
  "include": [
    "web",
    "vite.config.ts",
    "env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "web-dist"
  ]
}