# DeepSeek 走 Anthropic 兼容代理。本容器 shell 里 ANTHROPIC_* 通常已就绪，可留空由默认值兜底。
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_AUTH_TOKEN=sk-xxxx              # 你的 DeepSeek API key（走 x-api-key 头）

# 模型：flash 跑热回路（整流 + 意图路由），pro 跑写作 worker。留空则回退到 ANTHROPIC_* / 内置默认。
VOICE_MODEL_FLASH=deepseek-v4-flash
VOICE_MODEL_PRO=deepseek-v4-pro[1m]

# 运行参数（可选）
PORT=8080
VOICE_DB_PATH=./data/voice-agent.db
VOICE_AUDIO_DIR=./data/audio
